generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ContactInquiry {
  id               Int      @id @default(autoincrement())
  name             String
  email            String
  phone            String?
  company          String?
  website          String?
  businessType     String?
  turnover         String?
  service          String?
  budget           String?
  timeline         String?
  preferredDateTime DateTime?
  timezone         String?
  preferredMode    String?
  message          String
  createdAt        DateTime @default(now())
  isRead           Boolean  @default(false)

  @@map("contact_inquiries")
}

model Employee {
  id              Int      @id @default(autoincrement())
  name            String
  email           String   @unique
  role            String
  offerLetterLink String?
  joinedAt        DateTime @default(now())
  createdAt       DateTime @default(now())

  @@map("employees")
}

model SupportTicket {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@map("support_tickets")
}
